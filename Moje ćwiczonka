# PYTANIA:
# 1) jak zmieni się średnia roczna stopa wzrostu gospodarczego wkutek jednostkowego 
# wzrostu udziału handlu w gospodarce?

model1 <- lm(growth ~ tradeshare, data = GrowthSW)
summary(model1)

# odp: wkutek jednostkowego wzrostu udziału handlu w gospodarce średnia roczna stopa 
# wzrostu wzrośnie o 2,3064

# 2) czy zależność pomiędzy zmienną "growth" oraz "tradeshare" jest statystycznie 
# istotna? odp.uzasadnij

# ODP: Jest statystycznie istotna poniewaz p-v=0.00407jest mniejsze niz przyjętego poziomu istotności 
# alfa = 0,05, odrzucamy H0 i stwierdzamy, iż oszacowany paramentr jest statystycznie istotny

# 3) co oznacza błąd standardowy = 0.7735?

# Odp: Oznacza ze srednio mylimy sie o 0,7735 w szacowaiu wpływu parametry tradeshare 
# na poziomie 2,3064 na growth

# 4) wyznacz oraz zintepretuj przedziały ufności (95%) dla parametru stojącego przy "tradeshare"
confint(model1, level = 0.95)
# ODP: zakładamy z 95% pewnością parametr tradeshare mieści sie w przedziale 
# od 0.7607473 do 3.852120

# 5) dokonaj interpretacji R^2 oraz standardowego błędu regresji
# ODP: R2- model w 10,98% wyjaśnia kształtowanie sie zmiennej objasnianej growth.
# Standardowy błęd regresji - Residual standard error- SER - odchylenie pomiędzy 
# wartościami teoretycznymi a rzeczywistymi wynosi  1,79 pp

# 6) oceń, czy w modelu występuje normalność rozkładu składnika losowego oraz  
# heteroskestyczność. W przypadku heteroskedastyczności zastosuj błędy odporne i 
# porównaj je z pierwotnymi wynikami

#normalność rozkładu składnika losowego
jarque.bera.test(model1$residuals)
# HO: reszty mają rozkład normalny
# p-value = 0.2307 > 0,05
# brak podstwa do oddrzucenia H0 - reszty mają rozkład normalny

# Heteroskedastycznosc - zmiennosc wariancji
white(mainlm = model1)
# HO: reszty wykazują stałość wariancji
# p.value =  0.875 > 0,05
# brak podstaw do oddrzucenia H0 - reszty wykazują stałość wariancji

