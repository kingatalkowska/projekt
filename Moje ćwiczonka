install.packages("Ecdat")
library(Ecdat)

data("Icecream")
class(Icecream)
?Icecream

model3 <- lm(cons ~ income + price + temp, data = Icecream)
summary(model3)

# testy diagnostyczne

dwtest(model3)
bgtest(model3, order = 1)
bgtest(model3, order = 4)
shapiro.test(residuals(model3))
jarque.bera.test(residuals(model3))
bptest(model3)

# Model dynamiczny (AR(1))
