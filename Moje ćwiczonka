#    - y, czyli zużycie gazu,
#    - czas, czyli liniowy indeks czasu,
#    - kwartal, czyli zmienną sezonową.

dane_gas <- data.frame(
  y = as.numeric(UKgas),
  czas = 1:length(UKgas),
  kwartal = factor(cycle(UKgas)))

# Oszacuj model z trendem liniowym.
model71 <- lm(y ~ czas, data = dane_gas)
summary(model71)

# Zinterpretuj współczynnik przy zmiennej czas.
# ODP: z kwartału na kwartał zuzycie gazu wzrastało średnio o 5,9469

# Oszacuj model z trendem wykładniczym.
model72 <- lm(log(y) ~ czas, data = dane_gas)
summary(model72)

# Zinterpretuj współczynnik przy zmiennej czas w modelu wykładniczym.
# ODP: z kwartału na kwartał zuzycie gazu rosło przecietnie o 1,7887%

# Oszacuj model z trendem liniowym i sezonowością kwartalną.
model73 <- lm(y ~ czas + kwartal, data = dane_gas)
summary(model73)

# Zinterpretuj sezonowość.
# ODP: wszystkie wskaźniki sezonowości są istotne statystycznie, przeciętnie w każdym 2,3,4 
# kwartale zużycie gazu jest mniejsze kolejno o 42%, 99%, 34% niż w kwartale 1

# Oszacuj model z trendem wykładniczym i sezonowością kwartalną.
model74 <- lm(log(y) ~ czas + kwartal, data = dane_gas)
summary(model74)

# Oceń autokorelację reszt modelu z trendem wykładniczym i sezonowością
# za pomocą testu Durbina-Watsona oraz testu Breuscha-Godfreya.
reszty_sezon <- residuals(model74)

# Test Durbina-Watsona
dwtest(model74)
# H0: brak dodatniej autokorelacji reszt rzędu I
# H1: występuje dodatnia autokorelacja reszt rzędu I
# p-value = 0.1324 > 0.05, brak podstaw do odrzucenia H0.
# Autokorelacja reszt  rzędu I nie występuje 

# Test Breuscha-Godfreya
bgtest(model74, order = 4)
# H0: brak autokorelacji reszt do rzędu 4
# H1: występuje autokorelacja reszt do rzędu 4
# Ponieważ p-value = 6,02·10⁻¹⁵ < 0,05, odrzucamy H0. W modelu występuje 
# autokorelacja reszt do rzędu 4. Model wymaga poprawy 

