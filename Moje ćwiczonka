# Wykorzystaj dane Mroz87 z pakietu sampleSelection.
# Dane dotyczą aktywności zawodowej kobiet zamężnych.
# Zmienna lfp informuje, czy kobieta uczestniczy w rynku pracy.
# Celem zadania jest oszacowanie prawdopodobieństwa aktywności zawodowej
# kobiety za pomocą trzech modeli:
#
# 1) liniowego modelu prawdopodobieństwa, czyli LPM,
# 2) modelu probitowego,
# 3) modelu logitowego.
#
# Zmienną zależną będzie lfp:
# lfp = 1, jeżeli kobieta uczestniczy w rynku pracy,
# lfp = 0, jeżeli kobieta nie uczestniczy w rynku pracy.
#
# Zmienne objaśniające:
# nwifeinc - dochód rodziny poza dochodem żony,
# educ     - liczba lat edukacji,
# exper    - doświadczenie zawodowe,
# exper^2  - kwadrat doświadczenia zawodowego,
# age      - wiek kobiety,
# kids5    - liczba dzieci w wieku poniżej 5 lat,
# kids618  - liczba dzieci w wieku od 6 do 18 lat.
#
# ZADANIE:
#
# 1) Wczytaj dane Mroz87
library (sampleSelection)
data("Mroz87")
?Mroz87
View(Mroz87)

# 2) Oszacuj liniowy model prawdopodobieństwa LPM.
model62<- lm(lfp ~ nwifeinc + educ + exper  + exper^2 + age + kids5 + kids618, 
             data = Mroz87)
summary(model62)

# 3) Zinterpretuj wybrane współczynniki modelu LPM.
# Zmienne statsytycznie istotne- p-v<0.5
# wzrost poziomu (educ) o jed. (zwiększa) przewidywane prawdop. lfp średnio o (0.039819)
# (nwifeinc) (-0.003327)
# (exper) (0.022572) 
# (age) (-0.017712)
# (kids5) (-0.271829)
# zminna kind618 nie jest statystycznie istotna
# wszystkie zmienne w modelu sa statystycznie istotne p-value: < 2.2e-16

# 4) Oszacuj model probitowy.
model64 <- glm(lfp ~ nwifeinc + educ + exper  + I(exper^2) + age + kids5 + kids618, 
               data = Mroz87,
               family = binomial(link = "probit"))

summary(model64)

# 5) Oszacuj model logitowy.
model65 <- glm(lfp ~ nwifeinc + educ + exper  + I(exper^2) + age + kids5 + kids618, 
               data = Mroz87,
               family = binomial(link = "logit"))

summary(model65)

# 6) Oblicz przewidywane prawdopodobieństwo aktywności zawodowej
# dla dwóch profili kobiet różniących się poziomem edukacji na podstawie modelu 
# probitowego oraz logitowego. porównaj wyniki
nowe <- data.frame(
  nwifeinc = c(mean(Mroz87$nwifeinc, na.rm = TRUE),
               mean(Mroz87$nwifeinc, na.rm = TRUE)),
  educ = c(12, 16),
  exper = c(10, 10),
  age = c(35, 35),
  kids5 = c(0, 0),
  kids618 = c(1, 1))

pred_probit1 <- predict(model64, newdata = nowe,  type = "response")
pred_probit1
pred_logit1 <- predict(model65, newdata = nowe,  type = "response")
pred_logit1

#ODP: Wzrost wykształcenia z 12 do 16 lat zwiększa prawdopodobieństwo pracy 
# o 11,5 pp w modelu probit i o 10,7 pp w modelu logit. Wyniki są zbliżone.

