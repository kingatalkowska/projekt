# w Wielkiej Brytanii. W tym zadaniu analizujemy zależność między liczbą 
# zabitych kierowców a liczbą przejechanych kilometrów.
data("Seatbelts")
?Seatbelts
class(Seatbelts)

# oszacuj model dynamiczny z opóźnieniami zmiennej kms
# Utwórz ramkę danych (PS. na kolokwium ramka danych będzie już przygotowana ;-))
dane_sb <- data.frame(
  kierowcy_zabici = as.numeric(Seatbelts[, "DriversKilled"]),
  kms = as.numeric(Seatbelts[, "kms"]))
n <- nrow(dane_sb)
# utwórz opóźnienia zmiennej kms
# wskaźnik z poprzedniego okresu
dane_sb$kms_1 <- c(NA, dane_sb$kms[1:(n - 1)])

# wskaźnik sprzed dwóch okresów
dane_sb$kms_2 <- c(NA, NA, dane_sb$kms[1:(n - 2)])

dane_dyn <- na.omit(dane_sb)

head(dane_dyn)

model75 <- lm(kierowcy_zabici ~ kms + kms_1 + kms_2,
                       data = dane_dyn)

summary(model75)
#ODP: wzrost bieżącej liczby kilometrów o 1 jednostkę wiąże się przeciętnie ze spadkiem
# liczby zabitych kierowców o około 0.0078, cet.par.

# Współczynnik przy kms_1 wynosi 0.0008069, ale nie jest statystycznie istotny, 
# ponieważ p-value = 0.684 > 0.05.Nie ma więc podstaw do stwierdzenia, że liczba kilometrów
# z poprzedniego miesiąca wpływa na bieżącą liczbę zabitych kierowców.

# wzrost liczby kilometrów sprzed dwóch miesięcy o 1 jednostkę wiąże się przeciętnie ze 
# wzrostem bieżącej liczby zabitych kierowców o około 0.0049, cet.par

#Możniki
m0 <- coef(model75)["kms"]
m1 <- coef(model75)["kms_1"]
m2 <- coef(model75)["kms_2"]
m0
m1
m2

